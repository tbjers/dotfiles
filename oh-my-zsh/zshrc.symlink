ZSH=$HOME/.dotfiles/oh-my-zsh
ZSH_THEME="agnoster"
DISABLE_AUTO_UPDATE="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"
plugins=(git cake composer bower gem git-extras github jake-node node npm nvm rake ruby rvm vagrant cl common-aliases)
source $ZSH/oh-my-zsh.sh
alias subl='open -a "Sublime Text"'
DEFAULT_USER=torgny
export EDITOR=vim
PATH=/usr/local/bin:$PATH
PATH=$PATH:$HOME/.dotfiles/bin:$HOME/bin:$PATH
[[ -s $HOME/.nvm/nvm.sh ]] && . $HOME/.nvm/nvm.sh # This loads NVM
eval "$(rbenv init -)"
